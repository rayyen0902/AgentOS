# Go service environment variables
# Copy this to .env and fill in the values

PORT=8080
ENV=development
ADMIN_API_KEY=<your-admin-api-key>
DATABASE_URL=postgres://agentos:<your-password>@localhost:5432/agentos?sslmode=disable
REDIS_URL=localhost:6379
PYTHON_SERVICE_URL=http://localhost:8000
PYTHON_SERVICE_TIMEOUT=35s
JWT_SECRET=<your-32-byte-jwt-secret>
JWT_EXPIRE=24h
RATE_LIMIT_GLOBAL=1000
RATE_LIMIT_USER_MSG=60
PLATFORM_SECRET_ENCRYPTION_KEY=<your-64-char-hex-aes-256-key>
ALERT_WEBHOOK_URL=<your-alert-webhook-url>
