PG_USER=agentos
PG_PASSWORD=<your-pg-password>
PG_DB=agentos
DATABASE_URL=postgres://agentos:<your-pg-password>@postgres:5432/agentos?sslmode=disable
REDIS_URL=redis:6379

PORT=8080
ENV=development
ADMIN_API_KEY=<your-admin-api-key>
JWT_SECRET=<your-jwt-secret-at-least-32-bytes>
JWT_EXPIRE=24h
RATE_LIMIT_GLOBAL=1000
RATE_LIMIT_USER_MSG=60
PLATFORM_SECRET_ENCRYPTION_KEY=<your-32-byte-hex-encryption-key>
ALERT_WEBHOOK_URL=<your-alert-webhook-url>
PYTHON_SERVICE_URL=http://python-service:8000
PYTHON_SERVICE_TIMEOUT=35s

LOG_LEVEL=INFO
LLM_FLASH_MODEL=qwen-turbo
LLM_PRO_MODEL=qwen-max
LLM_VL_MODEL=qwen-vl-plus
LLM_API_KEY=<your-dashscope-api-key>
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMS=1024
EMBEDDING_CACHE_TTL=3600
FE_GRPC_HOST=<your-fe-grpc-host>
FE_GRPC_PORT=50052
FE_GRPC_TIMEOUT=5
FE_KIN_ID=<your-kin-id>
TRACE_ENABLED=false
TRACE_SAMPLE_RATE=0.0
