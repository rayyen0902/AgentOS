# Frontend environment variables
# Copy this to .env and fill in the values

# API base URL — leave empty for local dev (uses Vite proxy to localhost:8080)
# Set to the full backend URL for production/staging (e.g. https://api.example.com)
VITE_API_BASE_URL=

# Maximum SSE reconnect attempts
VITE_SSE_RECONNECT_MAX=10

# Environment: development | staging | production
VITE_ENV=development
